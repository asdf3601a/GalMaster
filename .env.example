# ===== LLM API (pick what you use) =====
# Protocol: openai | anthropic
# LLM_PROTOCOL=openai
# LLM_PROVIDER=xai

# SpaceXAI / xAI (OpenAI-compatible)
XAI_API_KEY=your_api_key_here
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL=grok-4-1-fast-non-reasoning

# OpenAI official or any OpenAI-compatible gateway
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Anthropic official or Anthropic-compatible proxy
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Generic overrides (highest priority for URL/model when set)
# LLM_API_KEY=
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=llama3.2
